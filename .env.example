# Single-user bearer token checked on every /api request. Required, no default.
# Generate one with: openssl rand -hex 32
PASSAGE_AUTH_TOKEN=changeme

# SQLite database location. Defaults to ./data/passage.db for local dev.
# In production this points at the Fly volume mount, e.g. /data/passage.db.
# PASSAGE_DATABASE_PATH=./data/passage.db

# Built frontend directory to serve at `/`. Leave unset in development —
# the Vite dev server proxies /api and /health to this backend instead.
# PASSAGE_STATIC_DIR=
