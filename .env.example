# Single-user bearer token checked on every /api request. Required, no default.
# Generate one with: openssl rand -hex 32
PASSAGE_AUTH_TOKEN=changeme

# Postgres connection string. Required, no default.
# Local dev (Supabase CLI stack, `supabase start`): postgresql://postgres:postgres@127.0.0.1:54322/postgres
# Production: the Supabase project's POOLED (Supavisor, port 6543) connection string —
# not the direct connection string. Serverless functions must not hold direct connections.
PASSAGE_DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres

# Shared secret for the Vercel cron job that hits /api/cron/keepalive.
# Named without the PASSAGE_ prefix to match Vercel's cron convention. Generate one with:
# openssl rand -hex 32
CRON_SECRET=changeme
